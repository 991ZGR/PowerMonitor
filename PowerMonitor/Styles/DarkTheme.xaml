<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color Palette -->
    <Color x:Key="BgDark">#0B0B14</Color>
    <Color x:Key="BgCard">#16162A</Color>
    <Color x:Key="BgCardHover">#1E1E3A</Color>
    <Color x:Key="AccentCyan">#00F0FF</Color>
    <Color x:Key="AccentBlue">#4A90D9</Color>
    <Color x:Key="AccentOrange">#FF6B35</Color>
    <Color x:Key="AccentPurple">#A855F7</Color>
    <Color x:Key="AccentGreen">#22D65E</Color>
    <Color x:Key="TextPrimary">#F0F0FF</Color>
    <Color x:Key="TextSecondary">#8888AA</Color>
    <Color x:Key="TextDim">#555577</Color>
    <Color x:Key="GlowCyan">#1A00F0FF</Color>
    <Color x:Key="GlowOrange">#1AFF6B35</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BgCardHoverBrush" Color="{StaticResource BgCardHover}"/>
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource AccentCyan}"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDim}"/>

    <!-- Card Border Style -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#22FFFFFF"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="0" Color="#000000"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Glow Effect for Total Power -->
    <DropShadowEffect x:Key="CyanGlow" BlurRadius="30" Opacity="0.6" ShadowDepth="0" Color="{StaticResource AccentCyan}"/>
    <DropShadowEffect x:Key="OrangeGlow" BlurRadius="25" Opacity="0.5" ShadowDepth="0" Color="{StaticResource AccentOrange}"/>
    <DropShadowEffect x:Key="PurpleGlow" BlurRadius="25" Opacity="0.5" ShadowDepth="0" Color="{StaticResource AccentPurple}"/>
    <DropShadowEffect x:Key="GreenGlow" BlurRadius="25" Opacity="0.5" ShadowDepth="0" Color="{StaticResource AccentGreen}"/>

    <!-- Glass pane style -->
    <Style x:Key="GlassPane" TargetType="Border">
        <Setter Property="Background" Value="#0DFFFFFF"/>
        <Setter Property="CornerRadius" Value="16"/>
    </Style>

    <!-- Value label style -->
    <Style x:Key="ValueLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SubLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
