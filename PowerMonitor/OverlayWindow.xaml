<Window x:Class="PowerMonitor.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay"
        Width="180" Height="52"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        IsHitTestVisible="False"
        Cursor="None"
        WindowStartupLocation="Manual"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="0" GlassFrameThickness="0" CaptionHeight="0" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Border x:Name="MainBorder" CornerRadius="8" Background="#CC0A0A14"
                BorderThickness="1"
                Padding="12,8,14,8">
            <Border.BorderBrush>
                <SolidColorBrush Color="#33FFFFFF"/>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.4" ShadowDepth="2" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="6" Height="6"
                         VerticalAlignment="Center" Margin="0,0,8,0"
                         Fill="{DynamicResource AccentCyanBrush}">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="10" Opacity="0.9" ShadowDepth="0"
                                          Color="{StaticResource AccentCyan}"/>
                    </Ellipse.Effect>
                </Ellipse>

                <TextBlock x:Name="TotalPowerText" Grid.Column="1"
                           Text="— W" FontSize="24" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
